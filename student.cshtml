@model FileClass
@{ Layout = null; }

@if (Model != null)
{
<hr />
                <table class="table table-bordered table-striped" cellpadding="0" cellspacing="0" border="1">
                    <thead>
                        <tr>
                            <th>SL</th>
                            <th>PDF Name</th>
                            <th>Display Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (FileClass file in Model.Files)
                        {
        <tr>
            <td>@file.FileId</td>
            <td>@file.Name</td>
            <td>
                <a href="../Files/Index?filename=@file.Name" style="margin-right:10px;">Current Page</a>
                <a href="../Files/PDFViewerNewTab?filename=@file.Name" target="_blank">New Tab</a>
            </td>
        </tr>
}
                    </tbody>
                </table>
}

<br />
<br />
<embed id="embPDF" src="~ /files/@Model.Name" style="width:100; height:1200px;" />
